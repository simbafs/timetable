---
import Layout from '../layouts/Layout.astro'
import TimetableApp from '../components/TimetableApp'
---

<Layout title="課表排程">
	<main class="min-h-screen w-full bg-[#fafafa]">
		<div
			class="fixed inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px]"
		>
		</div>
		<div class="relative z-10 flex min-h-screen flex-col items-center py-12 sm:px-6 lg:px-8">
			<TimetableApp client:only="react" />
		</div>
	</main>
</Layout>
