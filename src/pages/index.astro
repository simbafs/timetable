---
import '../styles/global.css'
---

<html lang="zh-TW">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>課表設定</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-[100dvh] bg-zinc-50 text-zinc-900 font-sans">
		<div class="relative min-h-[100dvh] overflow-hidden">
			<div
				class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-emerald-100 via-zinc-50 to-zinc-50 opacity-60"
			>
			</div>
			<div
				class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-zinc-100 via-transparent to-transparent"
			>
			</div>

			<main class="relative z-10 flex min-h-[100dvh] items-center justify-center p-4 md:p-8">
				<div class="w-full max-w-xl">
					<header class="mb-8 text-center">
						<h1 class="text-3xl font-semibold tracking-tight text-zinc-800">課表設定</h1>
						<p class="mt-2 text-sm text-zinc-500">將課程匯入 Google 日曆</p>
					</header>

					<section
						id="auth-section"
						class="glass-panel mb-6 rounded-3xl border border-white/40 bg-white/60 p-8 shadow-[0_8px_32px_rgba(0,0,0,0.04)] backdrop-blur-xl"
					>
						<div class="flex flex-col items-center gap-6">
							<div
								class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 shadow-lg shadow-emerald-500/25"
							>
								<svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="1.5"
										d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
									></path>
								</svg>
							</div>
							<div class="text-center">
								<h2 class="text-lg font-medium text-zinc-700">授權管理</h2>
								<p class="mt-1 text-sm text-zinc-400">登入您的 Google 帳戶以授權修改日曆</p>
							</div>
							<button
								id="login-btn"
								class="group relative overflow-hidden rounded-xl bg-zinc-900 px-8 py-3 font-medium text-white transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:shadow-zinc-900/20 active:scale-[0.98]"
							>
								<span class="relative z-10 flex items-center gap-2">
									<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
										<path
											d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
										></path>
										<path
											d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
										></path>
										<path
											d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
										></path>
										<path
											d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
										></path>
									</svg>
									使用 Google 登入
								</span>
							</button>
						</div>
					</section>

					<form
						id="form"
						class="hidden glass-panel rounded-3xl border border-white/40 bg-white/60 p-8 shadow-[0_8px_32px_rgba(0,0,0,0.04)] backdrop-blur-xl"
					>
						<div class="mb-6 flex items-center justify-between border-b border-zinc-100 pb-4">
							<div class="flex items-center gap-3">
								<div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100">
									<svg
										class="h-5 w-5 text-emerald-600"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
										></path>
									</svg>
								</div>
								<div>
									<p id="user-info" class="text-sm font-medium text-zinc-700"></p>
									<p class="text-xs text-zinc-400">已授權</p>
								</div>
							</div>
							<button
								id="logout-btn"
								type="button"
								class="rounded-lg px-3 py-1.5 text-sm font-medium text-zinc-500 transition-colors hover:bg-zinc-100 hover:text-zinc-700"
							>
								登出
							</button>
						</div>

						<fieldset class="mb-6">
							<legend class="mb-3 text-sm font-medium text-zinc-600">學期起訖</legend>
							<div class="grid grid-cols-2 gap-4">
								<div class="space-y-1.5">
									<label for="startDate" class="text-xs font-medium text-zinc-500">第一天</label>
									<input
										type="date"
										id="startDate"
										class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-2.5 text-sm transition-all focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
										value="2025-02-17"
									/>
								</div>
								<div class="space-y-1.5">
									<label for="endDate" class="text-xs font-medium text-zinc-500">最後一天</label>
									<input
										type="date"
										id="endDate"
										class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-2.5 text-sm transition-all focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
										value="2025-06-20"
									/>
								</div>
							</div>
						</fieldset>

						<fieldset class="mb-6">
							<legend class="mb-3 text-sm font-medium text-zinc-600">日曆名稱</legend>
							<input
								type="text"
								id="calendar"
								class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-2.5 text-sm transition-all focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
								value="課表"
							/>
						</fieldset>

						<fieldset class="mb-6">
							<div class="mb-3 flex items-center justify-between">
								<legend class="text-sm font-medium text-zinc-600">課程列表</legend>
								<button
									id="add"
									type="button"
									class="flex items-center gap-1 rounded-lg px-2 py-1 text-sm font-medium text-emerald-600 transition-colors hover:bg-emerald-50"
								>
									<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M12 4v16m8-8H4"></path>
									</svg>
									新增
								</button>
							</div>
							<div class="rounded-xl border border-zinc-200 bg-white">
								<table class="w-full">
									<thead>
										<tr class="border-b border-zinc-100 bg-zinc-50/50">
											<th
												class="px-4 py-2.5 text-left text-xs font-medium uppercase tracking-wide text-zinc-400"
												>科目</th
											>
											<th
												class="px-4 py-2.5 text-left text-xs font-medium uppercase tracking-wide text-zinc-400"
												>星期</th
											>
											<th
												class="px-4 py-2.5 text-left text-xs font-medium uppercase tracking-wide text-zinc-400"
												>開始</th
											>
											<th
												class="px-4 py-2.5 text-left text-xs font-medium uppercase tracking-wide text-zinc-400"
												>結束</th
											>
											<th class="w-10"></th>
										</tr>
									</thead>
									<tbody id="lessons">
										<tr class="border-b border-zinc-50 last:border-0">
											<td class="p-2">
												<input
													placeholder="科目名稱"
													type="text"
													class="w-full rounded-lg border-0 bg-zinc-50 px-3 py-2 text-sm transition-all focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
													required
												/>
											</td>
											<td class="p-2">
												<input
													placeholder="1-7"
													type="number"
													min="1"
													max="7"
													class="w-16 rounded-lg border-0 bg-zinc-50 px-3 py-2 text-sm transition-all focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
													required
												/>
											</td>
											<td class="p-2">
												<input
													placeholder="1-9"
													type="number"
													min="1"
													max="9"
													class="w-16 rounded-lg border-0 bg-zinc-50 px-3 py-2 text-sm transition-all focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
													required
												/>
											</td>
											<td class="p-2">
												<input
													placeholder="1-9"
													type="number"
													min="1"
													max="9"
													class="w-16 rounded-lg border-0 bg-zinc-50 px-3 py-2 text-sm transition-all focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500/20"
													required
												/>
											</td>
											<td class="p-2">
												<button
													type="button"
													class="delete group flex h-8 w-8 items-center justify-center rounded-lg text-zinc-400 transition-all hover:bg-red-50 hover:text-red-500"
												>
													<svg
														class="h-4 w-4"
														fill="none"
														stroke="currentColor"
														viewBox="0 0 24 24"
													>
														<path
															stroke-linecap="round"
															stroke-linejoin="round"
															stroke-width="2"
															d="M6 18L18 6M6 6l12 12"></path>
													</svg>
												</button>
											</td>
										</tr>
									</tbody>
								</table>
							</div>
						</fieldset>

						<button
							type="submit"
							class="submit-btn group relative w-full overflow-hidden rounded-xl bg-gradient-to-r from-emerald-600 to-emerald-500 px-6 py-3.5 font-medium text-white shadow-lg shadow-emerald-500/25 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:shadow-emerald-500/30 active:scale-[0.99]"
						>
							<span class="relative z-10 flex items-center justify-center gap-2">
								<svg
									class="h-5 w-5 transition-transform group-hover:rotate-12"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								匯入日曆
							</span>
							<div
								class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-transform duration-700 group-hover:translate-x-full"
							>
							</div>
						</button>

						<div
							id="loading-overlay"
							class="pointer-events-none absolute inset-0 z-50 flex hidden items-center justify-center rounded-3xl bg-white/80 backdrop-blur-sm"
						>
							<div class="flex flex-col items-center gap-3">
								<div
									class="h-8 w-8 animate-spin rounded-full border-2 border-emerald-200 border-t-emerald-600"
								>
								</div>
								<p class="text-sm font-medium text-zinc-600">處理中...</p>
							</div>
						</div>
					</form>

					<footer class="mt-8 text-center">
						<p class="text-xs text-zinc-400">資料僅用於建立日曆事件，不會儲存</p>
					</footer>
				</div>
			</main>
		</div>

		<style>
			.glass-panel {
				box-shadow:
					0 8px 32px rgba(0, 0, 0, 0.04),
					inset 0 1px 0 rgba(255, 255, 255, 0.6);
			}
		</style>

		<script>
			const CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID
			const SCOPES = 'https://www.googleapis.com/auth/calendar'
			const DISABLE_AUTH = import.meta.env.PUBLIC_DISABLE_AUTH === 'true'
			let accessToken = localStorage.getItem('google_access_token')

			function getAuthUrl() {
				const params = new URLSearchParams({
					client_id: CLIENT_ID,
					redirect_uri: `${window.location.origin}/api/auth/callback`,
					response_type: 'token',
					scope: SCOPES,
					prompt: 'consent',
				})
				return `https://accounts.google.com/o/oauth2/v2/auth?${params}`
			}

			function updateUI() {
				const authSection = document.getElementById('auth-section')
				const form = document.getElementById('form')

				if (DISABLE_AUTH) {
					authSection.classList.add('hidden')
					form.classList.remove('hidden')
					const userInfo = document.getElementById('user-info')
					userInfo.textContent = '測試模式'
					return
				}

				if (accessToken) {
					authSection.classList.add('hidden')
					form.classList.remove('hidden')

					const payload = JSON.parse(atob(accessToken.split('.')[1]))
					const userInfo = document.getElementById('user-info')
					userInfo.textContent = payload.email || payload.sub
				} else {
					authSection.classList.remove('hidden')
					form.classList.add('hidden')
				}
			}

			document.getElementById('login-btn').addEventListener('click', () => {
				window.location.href = getAuthUrl()
			})

			document.getElementById('logout-btn').addEventListener('click', () => {
				localStorage.removeItem('google_access_token')
				accessToken = null
				updateUI()
			})

			if (window.location.hash) {
				const params = new URLSearchParams(window.location.hash.substring(1))
				const token = params.get('access_token')
				if (token) {
					localStorage.setItem('google_access_token', token)
					window.location.hash = ''
					window.location.pathname = '/'
				}
			}

			updateUI()

			function getDateBySemester() {
				const parseDate = dateStr => {
					const parts = dateStr.split('-')
					return [parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2])]
				}
				return {
					start: parseDate((document.getElementById('startDate') as HTMLInputElement).value),
					end: parseDate((document.getElementById('endDate') as HTMLInputElement).value),
				}
			}

			function setLoading(loading: boolean) {
				const overlay = document.getElementById('loading-overlay')
				const inputs = document.querySelectorAll('#form input, #form button')
				if (loading) {
					overlay.classList.remove('hidden')
				} else {
					overlay.classList.add('hidden')
				}
				inputs.forEach(el => {
					;(el as HTMLInputElement).disabled = loading
				})
			}

			function showMessage(data: { error?: string } | null) {
				setLoading(false)
				if (data?.error) {
					alert(data.error)
				} else if (data) {
					alert(JSON.stringify(data))
				} else {
					alert('成功！')
				}
			}

			document.getElementById('add').addEventListener('click', () => {
				const lessons = document.getElementById('lessons')
				const row = lessons.children[0].cloneNode(true) as HTMLElement
				const inputs = row.querySelectorAll('input')
				inputs.forEach(input => {
					if (input instanceof HTMLInputElement) input.value = ''
				})
				const deleteBtn = row.querySelector('.delete')
				if (deleteBtn) {
					deleteBtn.addEventListener('click', handleDelete)
				}
				lessons.appendChild(row)
			})

			function handleDelete(this: HTMLElement) {
				const lessons = document.getElementById('lessons')
				if (lessons.children.length <= 1) return
				this.closest('tr')?.remove()
			}

			document.querySelectorAll('.delete').forEach(btn => {
				btn.addEventListener('click', handleDelete)
			})

			document.getElementById('form').addEventListener('submit', async e => {
				e.preventDefault()
				if (!accessToken && !DISABLE_AUTH) {
					alert('請先登入')
					return
				}

				const data = {
					semester: getDateBySemester(),
					calendar: (document.getElementById('calendar') as HTMLInputElement).value,
					lessons: Array.from(document.querySelectorAll('#lessons tr')).map(row =>
						[1, 2, 3, 4].map(i => {
							const input = row.querySelector(`td:nth-child(${i}) input`)
							return (input as HTMLInputElement).value
						}),
					),
				}
				console.log(data)
				setLoading(true)

				try {
					const headers = { 'Content-Type': 'application/json' }
					if (accessToken) {
						headers['Authorization'] = `Bearer ${accessToken}`
					}
					const response = await fetch('/api/calendar', {
						method: 'POST',
						headers,
						body: JSON.stringify(data),
					})
					const result = await response.json()
					showMessage(result)
				} catch (err) {
					showMessage({ error: String(err) })
				}
			})
		</script>
	</body>
</html>
